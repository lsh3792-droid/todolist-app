{
  "permissions": {
    "allow": [
      "Bash(node -e ' *)",
      "PowerShell(Get-Command *)",
      "PowerShell(git config *)",
      "PowerShell(ssh -T git@github.com 2>&1)",
      "Bash(git checkout *)",
      "PowerShell(npm run *)",
      "Bash(npm run *)",
      "Bash(python -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\(json.dumps\\(d.get\\('exports', {}\\), indent=2\\)\\)\")",
      "Bash(node_modules/.bin/tsc --version)",
      "Bash(git rm *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "postgresql-mcp"
  ]
}
